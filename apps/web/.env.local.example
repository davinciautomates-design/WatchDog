# Copy to .env.local — never commit .env.local

# Internal API server URL (server-to-server, not exposed to browser)
API_URL="http://localhost:3001"

# Mapbox public token — restricted to your domain in Mapbox dashboard
# Get yours at: https://account.mapbox.com/access-tokens/
# NEXT_PUBLIC_ prefix makes it available in the browser bundle (safe for Mapbox tokens)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="pk.your_mapbox_public_token"

# Public vars (NEXT_PUBLIC_ prefix makes them available in the browser)
NEXT_PUBLIC_API_URL="http://localhost:3001"
