# Copy to .env.local — never commit .env.local

# Internal API server URL (server-to-server, not exposed to browser)
API_URL="http://localhost:3001"

# Mapbox token — stored server-side and proxied; never exposed to browser
MAPBOX_ACCESS_TOKEN="pk.your_mapbox_public_token"

# Public vars (NEXT_PUBLIC_ prefix makes them available in the browser)
NEXT_PUBLIC_API_URL="http://localhost:3001"
